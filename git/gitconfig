# git/gitconfig — tracked dotfile, symlinked to ~/.gitconfig by setup.sh
# Machine-specific settings (identity, credentials, signing key) live in
# ~/.gitconfig.local which is NOT tracked. See git/gitconfig.local.template.

[core]
    editor = vim
    excludesFile = ~/.gitignore_global
    autocrlf = input

[init]
    defaultBranch = main

[push]
    default = simple
    autoSetupRemote = true

[pull]
    rebase = false

[merge]
    ff = false

[diff]
    colorMoved = zebra

[color]
    ui = auto

[alias]
    st  = status
    co  = checkout
    br  = branch
    lg  = log --oneline --graph --decorate --all
    undo    = reset --soft HEAD~1
    unstage = restore --staged

[include]
    path = ~/.gitconfig.local
