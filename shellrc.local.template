# shellrc.local.template — machine-specific environment and aliases
#
# Copy to ~/.shellrc.local (done automatically by setup.sh).
# ~/.shellrc.local is NOT tracked by git — put secrets and
# machine-specific paths here, not in shellrc.
#
# This template IS tracked so every machine gets the same starting point.

# ---------------------------------------------------------------------------
# Identity / secrets
# (never put real values in shellrc or commit them to git)
# ---------------------------------------------------------------------------
# export GITHUB_TOKEN=""
# export AWS_ACCESS_KEY_ID=""
# export AWS_SECRET_ACCESS_KEY=""
# export SOME_API_KEY=""

# ---------------------------------------------------------------------------
# Machine-specific PATH entries
# ---------------------------------------------------------------------------
# export PATH="$HOME/.local/bin:$PATH"
# export PATH="/opt/homebrew/bin:$PATH"      # macOS ARM homebrew
# export PATH="/usr/local/bin:$PATH"         # macOS x86 homebrew

# ---------------------------------------------------------------------------
# Machine-specific aliases
# ---------------------------------------------------------------------------
# alias code='open -a "Visual Studio Code"'  # macOS
# alias pbcopy='xclip -selection clipboard'  # Linux equivalent
# alias work='cd ~/work/myproject'

# ---------------------------------------------------------------------------
# Machine-specific environment
# ---------------------------------------------------------------------------
# export EDITOR='nvim'
# export BROWSER='firefox'
# export JAVA_HOME='/usr/lib/jvm/java-17-openjdk'

# ---------------------------------------------------------------------------
# Work / personal profile toggle
# ---------------------------------------------------------------------------
# export GIT_AUTHOR_NAME="Your Name"
# export GIT_AUTHOR_EMAIL="you@example.com"
